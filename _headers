# index.htmlは常に最新を返す（キャッシュ禁止）
/
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

/index.html
  Cache-Control: no-store, no-cache, must-revalidate
  Pragma: no-cache

# CSS/JSはURLにバージョンクエリが付くので長期キャッシュOK
/styles.css
  Cache-Control: public, max-age=31536000, immutable

/app.bundle.js
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: no-store, no-cache, must-revalidate
